{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src"],
  "entryPointStrategy": "expand",
  "out": "docs-static",
  "name": "@s4ai/core Documentation",
  "includeVersion": true,
  "readme": "README.md",
  "categorizeByGroup": true,
  "categoryOrder": [
    "Autonomous",
    "Intelligence",
    "Monitoring",
    "Business",
    "Infrastructure",
    "*"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/*.test.js",
    "**/*.spec.js"
  ],
  "plugin": ["typedoc-plugin-markdown"],
  "excludePrivate": true,
  "tsconfig": "./tsconfig.json"
}
