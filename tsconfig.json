{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "maxNodeModuleJsDepth": 1,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.js",
    "**/*.spec.js"
  ]
}
